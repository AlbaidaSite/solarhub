# Variables para los tests E2E (npm run test:e2e).
# Copia este fichero como `.env.test` y rellena los valores con los que te
# devuelve `npx supabase status`.
#
# IMPORTANTE: `.env.test` debe estar en .gitignore (las claves service_role
# son sensibles, aunque las de un Supabase local son inocuas).

# URL de la instancia local. Por defecto la del CLI.
SUPABASE_E2E_URL=http://127.0.0.1:54321

# Clave pública anon (devuelta como "anon key" por `npx supabase status`).
SUPABASE_E2E_ANON_KEY=

# Clave de servicio (devuelta como "service_role key" por `npx supabase status`).
# Bypasea RLS — solo en tests.
SUPABASE_E2E_SERVICE_ROLE_KEY=
